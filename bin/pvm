#!/usr/bin/env bash

set -euo pipefail

PVM_VERSION_STRING="0.3.1"

resolve_path() {
  local source_path="$1"
  local source_dir

  while [[ -L "$source_path" ]]; do
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done

  printf '%s\n' "$source_path"
}

SCRIPT_PATH="$(resolve_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PVM_PROJECT_ROOT="$(cd -P "$SCRIPT_DIR/.." && pwd)"
PVM_DIR="${PVM_DIR:-$HOME/.pvm}"
PVM_SHIMS_DIR="$PVM_DIR/shims"
PVM_DEFAULT_FILE="$PVM_DIR/default-version"
PVM_TOOLS_DIR="$PVM_DIR/tools"
PVM_COMPOSER_DIR="$PVM_TOOLS_DIR/composer"
PVM_COMPOSER_BIN="$PVM_COMPOSER_DIR/composer"
PVM_USER_BIN_DIR="${PVM_USER_BIN_DIR:-$HOME/.local/bin}"
PVM_USER_COMPOSER_LINK="$PVM_USER_BIN_DIR/composer"
PVM_COMPOSER_INSTALLER_URL="${PVM_COMPOSER_INSTALLER_URL:-https://getcomposer.org/installer}"
PVM_COMPOSER_INSTALLER_SIG_URL="${PVM_COMPOSER_INSTALLER_SIG_URL:-https://composer.github.io/installer.sig}"

if [[ -t 2 && "${NO_COLOR-}" != "1" ]]; then
  PVM_COLOR=1
else
  PVM_COLOR=0
fi

source "$PVM_PROJECT_ROOT/libexec/pvm-core.sh"
source "$PVM_PROJECT_ROOT/libexec/pvm-brew.sh"
source "$PVM_PROJECT_ROOT/libexec/pvm-extensions.sh"
source "$PVM_PROJECT_ROOT/libexec/pvm-composer.sh"
source "$PVM_PROJECT_ROOT/libexec/pvm-commands.sh"

assert_safe_user_context "${1:-help}"

main "$@"
